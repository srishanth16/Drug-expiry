# CareWise Backend Environment Configurations
SECRET_KEY=your-super-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# Connection URI for MongoDB Atlas (leave blank to run in file-based Mock DB mode)
MONGO_URI=

# Google Gemini API Key for AI chat assistant & dynamic OCR translations
GEMINI_API_KEY=

# Email Configuration (for expiry alerts)
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-email-app-password
EMAIL_RECEIVER=receiver-email@example.com
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587

# Server Ports
PORT=5000
DEBUG=True
